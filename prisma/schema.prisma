generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// STAGE 1: Market Intelligence + Audience Research
// =====================================================
model IntelligenceEntry {
  id                String   @id @default(cuid())
  dateCaptured      DateTime @default(now())
  brand             String   // TBF, RA1, ShotIQ, HoS, Bookmark, all
  category          String   // audience, competitor, platform, local_market, industry, pricing, seasonal
  source            String
  insight           String   @db.Text
  actionable        Boolean  @default(false)
  actionRecommended String?  @db.Text
  priority          String   @default("medium") // high, medium, low
  status            String   @default("new") // new, actioned, archived
  connectedCampaign String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// =====================================================
// STAGE 2: Campaign Strategy Engine (Brand Pods)
// =====================================================
model BrandPod {
  id              String   @id @default(cuid())
  brand           String   @unique // TBF, RA1, ShotIQ, HoS, Bookmark
  name            String
  audience        String   @db.Text
  coreOffer       String   @db.Text
  coreMessage     String   @db.Text
  channelMix      Json     @default("{}") // channel -> budget % allocation
  kpiTargets      Json     @default("{}") // target metrics
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  campaigns       Campaign[]
  messagingLanes  MessagingLane[]
}

model MessagingLane {
  id          String   @id @default(cuid())
  brandPodId  String
  brandPod    BrandPod @relation(fields: [brandPodId], references: [id])
  lane        String   // e.g., "Fundamentals", "Transformation", "Free Trial"
  message     String   @db.Text
  contentTypes String  @db.Text // comma-separated
  target      String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id              String   @id @default(cuid())
  brandPodId      String
  brandPod        BrandPod @relation(fields: [brandPodId], references: [id])
  name            String
  messagingLane   String
  goal            String   // awareness, lead_gen, enrollment, sign_up, retention, event_promotion
  targetAudience  String   @db.Text
  offer           String?  @db.Text
  channels        Json     @default("[]") // array of channel names
  budget          Float    @default(0)
  budgetSpent     Float    @default(0)
  horizon         String   @default("H2") // H1 (locked), H2 (flexible), H3 (strategic)
  status          String   @default("draft") // draft, assembling, quality_gate, approved, live, paused, completed, killed
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  assemblies      CampaignAssembly[]
  qualityReviews  QualityGateReview[]
  deployments     ChannelDeployment[]
  performance     PerformanceMetric[]
}

// =====================================================
// STAGE 2.5: Creative Briefs (Marketing → Content)
// =====================================================
model CreativeBrief {
  id                 String   @id @default(cuid())
  brand              String
  campaignName       String
  campaignGoal       String
  targetAudience     String   @db.Text
  messagingLane      String
  keyMessage         String   @db.Text
  cta                String
  assetsNeeded       Json     @default("[]") // array of {type, quantity, platform, requirements}
  styleReference     String?
  deadline           DateTime?
  budgetNotes        String?
  priority           String   @default("standard") // urgent, standard, backlog
  status             String   @default("submitted") // submitted, acknowledged, in_production, delivered, cancelled
  contentResponse    String?  @db.Text
  deliveredAssets    Json     @default("[]")
  submittedAt        DateTime @default(now())
  acknowledgedAt     DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// =====================================================
// STAGE 3: Campaign Assembly Line
// =====================================================
model CampaignAssembly {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id])
  step          Int      // 1-7 (brief, copy, funnel, ad assembly, email, social, quality gate)
  stepName      String
  status        String   @default("pending") // pending, in_progress, completed, blocked
  copyText      Json?    @default("{}") // ad copy, email copy, landing page copy
  funnelConfig  Json?    @default("{}") // landing page, forms, automation
  adConfig      Json?    @default("{}") // ad sets, targeting, budget, A/B tests
  emailConfig   Json?    @default("{}") // sequences, triggers
  socialConfig  Json?    @default("{}") // posting schedule, boost config
  notes         String?  @db.Text
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =====================================================
// STAGE 4: Quality Gate + Brand Compliance
// =====================================================
model QualityGateReview {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id])
  reviewType     String   @default("pre_launch") // pre_launch, mid_campaign, post_campaign
  brandCompliance Json    @default("{}") // checklist results
  messagingCheck  Json    @default("{}") // accuracy checks
  funnelCheck     Json    @default("{}") // technical checks
  adCompliance    Json    @default("{}") // platform compliance
  decision        String  @default("pending") // pending, pass, revise, reject
  revisionNotes   String? @db.Text
  escalatedToJane Boolean @default(false)
  escalationReason String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =====================================================
// STAGE 5: Channel Deployment + Distribution
// =====================================================
model ChannelDeployment {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id])
  channel       String   // instagram, tiktok, facebook, youtube, email, google_ads, sms, twitter, linkedin
  platform      String?  // organic, paid, boosted
  contentAssets Json     @default("[]") // asset IDs used
  adCreative    Json?    @default("{}") // ad-specific config
  schedule      Json?    @default("{}") // posting/ad schedule
  budget        Float    @default(0)
  budgetSpent   Float    @default(0)
  status        String   @default("scheduled") // scheduled, live, paused, completed
  launchedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =====================================================
// STAGE 6: Performance Tracking + Revenue Attribution
// =====================================================
model PerformanceMetric {
  id                  String   @id @default(cuid())
  campaignId          String
  campaign            Campaign @relation(fields: [campaignId], references: [id])
  brand               String
  channel             String
  dateRange           String
  // Awareness
  impressions         Int      @default(0)
  reach               Int      @default(0)
  frequency           Float    @default(0)
  videoViews          Int      @default(0)
  brandSearchLift     Float    @default(0)
  // Engagement
  clicks              Int      @default(0)
  ctr                 Float    @default(0)
  engagementRate      Float    @default(0)
  landingPageVisits   Int      @default(0)
  // Conversion
  leadsGenerated      Int      @default(0)
  leadConversionRate  Float    @default(0)
  costPerLead         Float    @default(0)
  enrollments         Int      @default(0)
  enrollmentRate      Float    @default(0)
  costPerEnrollment   Float    @default(0)
  revenueGenerated    Float    @default(0)
  // Efficiency
  roas                Float    @default(0)
  cpa                 Float    @default(0)
  ltvToCpaRatio       Float    @default(0)
  budgetSpent         Float    @default(0)
  // Email
  openRate            Float    @default(0)
  clickRate           Float    @default(0)
  unsubscribeRate     Float    @default(0)
  // Attribution
  attributionModel    String   @default("last_touch") // first_touch, last_touch, multi_touch
  touchpoints         Json     @default("[]")
  recordedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// =====================================================
// STAGE 7: Learning Engine
// =====================================================
model LearningRule {
  id            String   @id @default(cuid())
  brand         String
  dataSource    String   @db.Text // which campaigns generated this
  rule          String   @db.Text
  confidence    String   @default("medium") // high, medium, low
  appliesTo     String   // pipeline stage(s)
  loopType      String   // campaign_pattern, funnel_optimization, content_feedback, seasonal, competitive
  status        String   @default("active") // active, testing, deprecated
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FunnelAnalysis {
  id            String   @id @default(cuid())
  brand         String
  funnelName    String   // e.g., "TBF Free Trial", "ShotIQ SaaS Adoption"
  stages        Json     @default("[]") // array of {stage, conversionRate, dropOffReason, fix}
  weakestLink   String?
  improvement   String?  @db.Text
  analysisDate  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContentFeedback {
  id              String   @id @default(cuid())
  brand           String
  period          String
  topPerforming   Json     @default("[]") // asset performance data
  worstPerforming Json     @default("[]")
  contentGaps     Json     @default("[]")
  formatInsights  Json     @default("[]")
  sentToContent   Boolean  @default(false)
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SeasonalPattern {
  id          String   @id @default(cuid())
  brand       String
  observation String   @db.Text
  action      String   @db.Text
  months      Json     @default("[]") // affected months
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =====================================================
// TV Show Marketing
// =====================================================
model TVShowMarketing {
  id            String   @id @default(cuid())
  brand         String
  showName      String
  format        String   // e.g., "10-12 min deep dive"
  cadence       String   // e.g., "1x/week"
  marketingRole String   @db.Text
  episodes      Int      @default(0)
  avgWatchDuration Float @default(0)
  leadsPerEpisode  Float @default(0)
  status        String   @default("active") // active, keep, optimize, cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =====================================================
// MyMemo Curation System
// =====================================================
model MyMemo {
  id            String   @id @default(cuid())
  brand         String   // TBF, RA1, ShotIQ, HoS, Bookmark, multiple
  messagingLane String?
  formatIdea    String   // clip_idea, tweet_swipe, design_reference, ad_concept, email_concept, funnel_idea
  content       String   @db.Text // the link, note, screenshot ref
  whySaved      String   @db.Text
  priority      String   @default("bank_for_later") // use_this_week, use_soon, bank_for_later
  status        String   @default("new") // new, briefed, produced, archived
  linkedBriefId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =====================================================
// Content Delivery Hub Assets (received from Content Division)
// =====================================================
model ContentAsset {
  id                    String   @id @default(cuid())
  assetId               String   @unique // external asset ID from Content Division
  brand                 String
  messagingLane         String?
  skillPillar           String?
  format                String   // short_video, mid_video, long_video, carousel, etc.
  platformOptimized     String   // tiktok, ig_reels, youtube_shorts, etc.
  dimensions            String?  // 9:16, 1:1, 4:5, 16:9
  duration              Int?     // seconds
  campaignId            String?  // if produced for specific campaign
  tvShow                String?
  captionText           String?  @db.Text
  hashtags              String?
  ctaText               String?
  performancePrediction Float?
  status                String   @default("new") // new, assigned_to_campaign, deployed, archived
  deliveredAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// =====================================================
// UNIFIED MARKETING PIPELINE (Software-CC style)
// =====================================================
model MarketingItem {
  id              String   @id @default(cuid())
  title           String
  brand           String
  source          String   @default("manual")
  sourceUrl       String?
  contentPreview  String?  @db.Text
  contentType     String   @default("social")
  currentStage    Int      @default(1)
  status          String   @default("active")
  pipelineMode    String   @default("manual")
  priorityScore   Int      @default(50)
  emailDraft      Json?    @default("{}")
  assemblyConfig  Json?    @default("{}")
  deploymentData  Json?    @default("{}")
  performanceData Json?    @default("{}")
  qualityScore    Float?   @default(0)
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  recycledFromId  String?
  metadata        Json?    @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  logs            MarketingPipelineLog[]
}

model MarketingPipelineLog {
  id        String   @id @default(cuid())
  itemId    String
  item      MarketingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  stage     Int
  stageName String
  action    String
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model BrandEmailConfig {
  id                   String  @id @default(cuid())
  brand                String  @unique
  sendfoxListId        String?
  acumbamailListId     String?
  defaultEmailPlatform String  @default("sendfox")
  emailTemplateId      String?
  emailFromName        String?
  emailReplyTo         String?
  brandColor           String?
  ctaUrl               String?
}

model CollectedContact {
  id        String   @id @default(cuid())
  email     String
  name      String?
  brand     String?
  source    String   @default("manual")
  sourceId  String?
  synced    Boolean  @default(false)
  syncedTo  String?
  createdAt DateTime @default(now())

  @@unique([email, brand])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @default(now())
}

// =====================================================
// CONTENT DISTRIBUTION PIPELINE (Content Hub → Marketing)
// =====================================================
model ContentBuffer {
  id            String        @id @default(cuid())
  contentType   String        // repurposed, graphic, blog, newsletter, workflow, game_result
  title         String
  brand         String
  sourceId      String        @unique
  sourceUrl     String?
  thumbnail     String?
  contentBody   String?       @db.Text
  metadata      Json?         @default("{}")
  status        String        @default("buffered") // buffered, batched, sent
  batchId       String?
  batch         ContentBatch? @relation(fields: [batchId], references: [id])
  createdAt     DateTime      @default(now())
}

model ContentBatch {
  id            String          @id @default(cuid())
  contentType   String
  brand         String
  batchSize     Int             @default(0)
  targetSize    Int             @default(4)
  status        String          @default("filling") // filling, ready, approved, scheduled, sent, failed
  templateHtml  String?         @db.Text
  mauticEmailId Int?
  scheduledFor  DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  sentAt        DateTime?
  createdAt     DateTime        @default(now())
  items         ContentBuffer[]
}

// =====================================================
// SUBSCRIBER INTELLIGENCE
// =====================================================
model Subscriber {
  id              String    @id @default(cuid())
  email           String
  firstName       String?
  lastName        String?
  brand           String
  source          String?   // mautic, sendfox, acumbamail, manual, formbricks
  externalId      String?
  engagementTier  String    @default("new") // hot, warm, cold, inactive, new
  engagementScore Int       @default(50)
  totalOpens      Int       @default(0)
  totalClicks     Int       @default(0)
  totalBounces    Int       @default(0)
  totalSent       Int       @default(0)
  lastOpenedAt    DateTime?
  lastClickedAt   DateTime?
  subscribedAt    DateTime  @default(now())
  suppressedAt    DateTime?
  suppressReason  String?
  tags            String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  events          SubscriberEvent[]

  @@unique([email, brand])
}

model SubscriberEvent {
  id            String     @id @default(cuid())
  subscriberId  String
  subscriber    Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  eventType     String     // open, click, bounce, unsubscribe, send
  emailSubject  String?
  batchId       String?
  metadata      Json?      @default("{}")
  createdAt     DateTime   @default(now())
}

model EmailAnalytics {
  id            String    @id @default(cuid())
  batchId       String?
  mauticEmailId Int?
  brand         String
  contentType   String
  subject       String
  totalSent     Int       @default(0)
  totalOpens    Int       @default(0)
  uniqueOpens   Int       @default(0)
  totalClicks   Int       @default(0)
  uniqueClicks  Int       @default(0)
  bounces       Int       @default(0)
  unsubscribes  Int       @default(0)
  openRate      Float?
  clickRate     Float?
  sentAt        DateTime?
  lastSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
}

// =====================================================
// SUBSCRIBER GROWTH SNAPSHOTS (for charting over time)
// =====================================================
model SubscriberSnapshot {
  id          String   @id @default(cuid())
  brand       String
  totalCount  Int      @default(0)
  hotCount    Int      @default(0)
  warmCount   Int      @default(0)
  coldCount   Int      @default(0)
  inactiveCount Int    @default(0)
  newCount    Int      @default(0)
  suppressedCount Int  @default(0)
  snapshotDate DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([brand, snapshotDate])
}

// =====================================================
// MARKET RESEARCH & ACQUISITION CHANNELS
// =====================================================

model TerritoryZone {
  id                String   @id @default(cuid())
  name              String
  zone              Int      @default(1)
  towns             String[] @default([])
  population        Int      @default(0)
  driveTime         String   @default("0 min")
  priority          String   @default("MEDIUM")
  brand             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Competitor {
  id                String    @id @default(cuid())
  name              String
  type              String    @default("regional_facility")
  location          String?
  distanceMiles     Float?
  website           String?
  strengths         String?
  weaknesses        String?
  recentChanges     String?
  lastScrapedAt     DateTime?
  brand             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model LeadSource {
  id                  String    @id @default(cuid())
  name                String
  category            String    @default("inbound")
  type                String    @default("organic")
  brand               String    @default("TBF")
  config              Json?
  schedule            String?
  totalLeads          Int       @default(0)
  qualifiedRate       Float     @default(0)
  enrollmentRate      Float     @default(0)
  costPerLead         Float     @default(0)
  costPerEnrollment   Float     @default(0)
  verdict             String    @default("maintain")
  status              String    @default("active")
  lastRunAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model RecLeagueScout {
  id               String   @id @default(cuid())
  leagueName       String
  scoutName        String?
  town             String?
  zone             Int      @default(1)
  contactName      String?
  contactEmail     String?
  partnershipType  String   @default("skills_night")
  sponsorshipCost  Float    @default(0)
  seasonsPartnered Int      @default(0)
  leadsPerSeason   Int      @default(0)
  enrollments      Int      @default(0)
  status           String   @default("prospect")
  notes            String?
  brand            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TravelProgram {
  id               String   @id @default(cuid())
  name             String
  organization     String?
  town             String?
  zone             Int?
  ageGroups        String?
  contactName      String?
  contactEmail     String?
  partnershipType  String?  @default("scouting")
  status           String?  @default("prospect")
  brand            String?
  leadsGenerated   Int?     @default(0)
  enrollments      Int?     @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CYOProgram {
  id               String   @id @default(cuid())
  name             String
  parish           String?
  town             String?
  zone             Int?
  ageGroups        String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  partnershipType  String?
  status           String?  @default("prospect")
  brand            String?
  leadsGenerated   Int?     @default(0)
  enrollments      Int?     @default(0)
  seasonSchedule   String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SchoolPartnership {
  id             String   @id @default(cuid())
  schoolName     String
  contactName    String?
  town           String?
  zone           Int?
  brand          String?
  status         String?  @default("prospect")
  leadsGenerated Int?     @default(0)
  enrollments    Int?     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ReferralEngine {
  id            String   @id @default(cuid())
  referrerName  String
  referredName  String
  status        String   @default("pending")
  brand         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommunityEvent {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  location    String
  brand       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NurtureSequence {
  id        String   @id @default(cuid())
  name      String
  brand     String   @default("TBF")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeasonalCalendar {
  id          String   @id @default(cuid())
  eventName   String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
