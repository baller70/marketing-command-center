{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pipeline/layout,_N_T_/pipeline/performance/layout,_N_T_/pipeline/performance/page,_N_T_/pipeline/performance"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pipeline/performance/__PAGE__",
    "/pipeline/performance",
    "/pipeline",
    "/_index",
    "/_head"
  ]
}