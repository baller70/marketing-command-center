{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pipeline/layout,_N_T_/pipeline/assembly/layout,_N_T_/pipeline/assembly/page,_N_T_/pipeline/assembly"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pipeline/assembly/__PAGE__",
    "/pipeline/assembly",
    "/pipeline",
    "/_index",
    "/_head"
  ]
}