{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pipeline/layout,_N_T_/pipeline/control/layout,_N_T_/pipeline/control/page,_N_T_/pipeline/control"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pipeline/control/__PAGE__",
    "/pipeline/control",
    "/pipeline",
    "/_index",
    "/_head"
  ]
}