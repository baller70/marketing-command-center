{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pipeline/layout,_N_T_/pipeline/content-assets/layout,_N_T_/pipeline/content-assets/page,_N_T_/pipeline/content-assets"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pipeline/content-assets/__PAGE__",
    "/pipeline/content-assets",
    "/pipeline",
    "/_index",
    "/_head"
  ]
}