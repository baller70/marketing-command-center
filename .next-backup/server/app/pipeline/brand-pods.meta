{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/pipeline/layout,_N_T_/pipeline/brand-pods/layout,_N_T_/pipeline/brand-pods/page,_N_T_/pipeline/brand-pods"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/pipeline/brand-pods/__PAGE__",
    "/pipeline/brand-pods",
    "/pipeline",
    "/_index",
    "/_head"
  ]
}